// 1. This tells Prisma where to look for your database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. This tells Prisma to generate a "Client" (the code we use to talk to the DB)
generator client {
  provider = "prisma-client-js"
}

// 3. THE MODELS

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  password        String
  projects        Project[]
  
  // Tasks assigned TO this user
  assignedTasks   Task[]    @relation("TaskAssignee")
  // Tasks created BY this user
  createdTasks    Task[]    @relation("TaskAssigner")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM) // NEW: How important is it?
  
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])

  // NEW: Who assigned it?
  assignerId  String
  assigner    User       @relation("TaskAssigner", fields: [assignerId], references: [id])

  // NEW: Who is doing it? (Optional, as a task might start unassigned)
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// 4. THE ENUMS
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
